---
const BEATS = [
  { badge: "Architecture",   title: "The full system",      text: "Six services, one production ERP — built, wired, and deployed solo from the first commit." },
  { badge: "Frontend",       title: "React · 5 modules",    text: "Role-based dashboards for HR, inventory, finance, and operations — all in one React SPA." },
  { badge: "Backend",        title: "Django REST API",       text: "Python handles all business logic, auth, and data validation — one API serving every module." },
  { badge: "Data layer",     title: "PostgreSQL on AWS RDS", text: "Relational store with managed backups, automated failover, and zero-downtime migrations." },
  { badge: "Infrastructure", title: "Docker + Kubernetes",   text: "Containerised and orchestrated — auto-scaling, rolling deployments, 99.9% uptime in prod." },
];
const FOCUS = [null, "react", "django", "postgres", "k8s"];
---

<!--
  No intro div above the section — the heading lives INSIDE the canvas overlay
  so there is zero dead space between the heading and the 3D nodes.
-->
<section
  id="erp-section"
  aria-label="ERP system architecture"
  style="height:600vh;background:var(--color-bg)"
>
  <div id="erp-sticky" style="position:sticky;top:0;height:100vh;overflow:hidden">
    <canvas id="erp-canvas" style="position:absolute;inset:0;width:100%;height:100%"></canvas>

    <!-- Heading overlay — sits above the nodes in beat 0, fades out on beat 1+ -->
    <div id="erp-hero"
      class="pointer-events-none absolute left-6 right-6 sm:left-8 sm:max-w-lg"
      style="top:72px;z-index:10;transition:opacity 0.5s">
      <p class="hud mb-2">DEEP DIVE</p>
      <h2 class="display text-3xl sm:text-4xl">
        Architecture of the<br />
        <span class="text-[var(--color-aurora)] [text-shadow:0_0_24px_oklch(0.8_0.165_162/0.35)]">ERP I built</span>
      </h2>
      <p class="mt-3 max-w-xs text-sm leading-relaxed text-[var(--color-body)]">
        Scroll to walk through every layer — from the React frontend to the Kubernetes cluster.
      </p>
    </div>

    <!-- HTML node labels — pill-style with dark bg so they're readable on any node colour -->
    <div style="position:absolute;inset:0;pointer-events:none" aria-hidden="true">
      <span id="lbl-react"    class="erp-lbl">React Frontend</span>
      <span id="lbl-django"   class="erp-lbl">Python Django API</span>
      <span id="lbl-postgres" class="erp-lbl">PostgreSQL · RDS</span>
      <span id="lbl-k8s"      class="erp-lbl">Kubernetes · Docker</span>
    </div>

    <!-- Caption card -->
    <div class="absolute bottom-6 left-1/2 w-[min(440px,88vw)] -translate-x-1/2 rounded-2xl border border-[oklch(0.8_0.165_162/0.45)] bg-[oklch(0.09_0.02_160/0.9)] p-5 backdrop-blur-md">
      <div id="erp-dots" class="mb-3 flex gap-1.5">
        {BEATS.map((_, i) => (
          <span class="erp-dot block h-1.5 rounded-full transition-all duration-300"
            style={`width:${i===0?"20px":"6px"};background:${i===0?"var(--color-aurora)":"oklch(0.32 0.02 160 / 0.5)"}`}></span>
        ))}
      </div>
      <p id="erp-badge" class="mb-1 font-mono text-[10px] uppercase tracking-widest text-[var(--color-aurora)]">{BEATS[0].badge}</p>
      <h3 id="erp-title" class="mb-1.5 font-bold text-[var(--color-ink)]">{BEATS[0].title}</h3>
      <p  id="erp-text"  class="text-sm leading-relaxed text-[var(--color-body)]">{BEATS[0].text}</p>
    </div>
  </div>
</section>

<script id="erp-beats" type="application/json" set:html={JSON.stringify({ beats: BEATS, focus: FOCUS })}></script>

<style>
  /* Dark-pill label — legible on the glowing green nodes AND the black background */
  .erp-lbl {
    position: absolute; left: 0; top: 0;
    display: inline-block;
    padding: 3px 7px;
    background: oklch(0.08 0.02 160 / 0.82);
    border: 1px solid oklch(0.8 0.165 162 / 0.45);
    border-radius: 4px;
    font-family: var(--font-mono, monospace);
    font-size: 0.58rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: #ffffff;
    white-space: nowrap;
    pointer-events: none;
    transition: opacity 0.4s;
    backdrop-filter: blur(4px);
  }
</style>

<script>
import * as THREE from "three";
import gsap from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

gsap.registerPlugin(ScrollTrigger);

const canvas = document.getElementById("erp-canvas") as HTMLCanvasElement | null;
if (!canvas || (canvas as any)._erpInit) { /* already running */ } else {
(canvas as any)._erpInit = true;

const rawData = JSON.parse(document.getElementById("erp-beats")?.textContent || "{}");
const BEATS: { badge: string; title: string; text: string }[] = rawData.beats ?? [];
const FOCUS: (string | null)[] = rawData.focus ?? [];

const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;

const AURORA     = 0x00dc82;
const AURORA_DIM = 0x003322;

// ── Renderer ──────────────────────────────────────────────────────────────
const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
renderer.setPixelRatio(Math.min(devicePixelRatio, 2));

const scene  = new THREE.Scene();
const camera = new THREE.PerspectiveCamera(55, 1, 0.1, 100);

const POS: Record<string, THREE.Vector3> = {
  react:    new THREE.Vector3( 0,    2,    0),
  django:   new THREE.Vector3( 0,   -0.5,  0),
  postgres: new THREE.Vector3(-3,   -3,    0),
  k8s:      new THREE.Vector3( 3,   -3,    0),
};

// Overview camera — z=8.5 (closer than v1's 11.5) so nodes fill more of the frame
camera.position.set(0, -0.5, 8.5);
const camTarget = new THREE.Vector3(0, -0.5, 0);

scene.add(new THREE.AmbientLight(0x112211, 2.5));
const pLight = new THREE.PointLight(AURORA, 4, 30);
pLight.position.set(0, 5, 7);
scene.add(pLight);

// ── Nodes ─────────────────────────────────────────────────────────────────
const nodes: Record<string, THREE.Mesh> = {};
const wireframes: Record<string, { mesh: THREE.Mesh; mat: THREE.MeshBasicMaterial }> = {};

Object.entries(POS).forEach(([key, pos]) => {
  const mat = new THREE.MeshStandardMaterial({
    color: AURORA_DIM, emissive: new THREE.Color(AURORA),
    emissiveIntensity: 0.1, roughness: 0.2, metalness: 0.9,
  });
  const mesh = new THREE.Mesh(new THREE.BoxGeometry(0.72, 0.72, 0.72), mat);
  mesh.position.copy(pos);
  scene.add(mesh);
  nodes[key] = mesh;

  const wMat = new THREE.MeshBasicMaterial({ color: AURORA, wireframe: true, transparent: true, opacity: 0 });
  const wMesh = new THREE.Mesh(new THREE.BoxGeometry(0.96, 0.96, 0.96), wMat);
  wMesh.position.copy(pos);
  scene.add(wMesh);
  wireframes[key] = { mesh: wMesh, mat: wMat };
});

// ── Connections ───────────────────────────────────────────────────────────
type Conn = { a: string; b: string; lineMat: THREE.LineBasicMaterial; particles: { mesh: THREE.Mesh; mat: THREE.MeshBasicMaterial }[] };
const conns: Conn[] = [];

([["react","django"],["django","postgres"],["django","k8s"]] as [string,string][]).forEach(([a, b]) => {
  const lineMat = new THREE.LineBasicMaterial({ color: AURORA, transparent: true, opacity: 0.1 });
  scene.add(new THREE.Line(
    new THREE.BufferGeometry().setFromPoints([POS[a].clone(), POS[b].clone()]),
    lineMat,
  ));
  const particles: { mesh: THREE.Mesh; mat: THREE.MeshBasicMaterial }[] = [];
  for (let i = 0; i < 5; i++) {
    const mat = new THREE.MeshBasicMaterial({ color: AURORA, transparent: true, opacity: 0 });
    const mesh = new THREE.Mesh(new THREE.SphereGeometry(0.055, 8, 8), mat);
    mesh.userData.t = i / 5;
    scene.add(mesh);
    particles.push({ mesh, mat });
  }
  conns.push({ a, b, lineMat, particles });
});

// ── Caption, heading overlay & highlights ─────────────────────────────────
const badgeEl = document.getElementById("erp-badge");
const titleEl = document.getElementById("erp-title");
const textEl  = document.getElementById("erp-text");
const dotEls  = document.querySelectorAll(".erp-dot");
const heroEl  = document.getElementById("erp-hero") as HTMLElement | null;

let lastBeat = -1;
function updateBeat(raw: number) {
  const beat = Math.min(Math.max(0, Math.floor(raw)), BEATS.length - 1);
  if (beat === lastBeat) return;
  lastBeat = beat;

  // Heading overlay: visible on beat 0, fades away on beats 1–4
  if (heroEl) heroEl.style.opacity = beat === 0 ? "1" : "0";

  const b = BEATS[beat];
  if (badgeEl) badgeEl.textContent = b.badge;
  if (titleEl) titleEl.textContent = b.title;
  if (textEl)  textEl.textContent  = b.text;
  dotEls.forEach((d, i) => {
    (d as HTMLElement).style.width      = i === beat ? "20px" : "6px";
    (d as HTMLElement).style.background = i <= beat ? "var(--color-aurora)" : "oklch(0.32 0.02 160 / 0.5)";
  });

  const focus = FOCUS[beat];
  Object.entries(nodes).forEach(([key, mesh]) => {
    const active = !focus || key === focus;
    gsap.to((mesh as any).material, { emissiveIntensity: active ? 2 : 0.05, duration: 0.5 });
    gsap.to(mesh.scale, { x: active ? 1.1 : 1, y: active ? 1.1 : 1, z: active ? 1.1 : 1, duration: 0.5 });
    gsap.to(wireframes[key].mat, { opacity: active ? 0.35 : 0, duration: 0.5 });
  });
  conns.forEach(({ a, b: nb, lineMat, particles }) => {
    const active = !focus || a === focus || nb === focus;
    gsap.to(lineMat, { opacity: active ? 0.6 : 0.06, duration: 0.5 });
    particles.forEach(({ mat }) => gsap.to(mat, { opacity: active ? 0.95 : 0, duration: 0.5 }));
  });
}

// ── Camera timeline (dwell pattern) ───────────────────────────────────────
const D = 0.82; // hold fraction per beat
const T = 0.18; // quick-transition fraction

const tl = gsap.timeline({ paused: true });

tl// Beat 0: hold at overview (z=8.5, closer so nodes fill the frame)
  .to(camera.position, { x: 0, y: -0.5, z: 8.5, ease: "none", duration: D })
  .to(camTarget,        { x: 0, y: -0.5,         ease: "none", duration: D }, "<")
// → React
  .to(camera.position, { x: 0, y: 1.2,  z: 5.5, ease: "power3.out", duration: T })
  .to(camTarget,        { x: 0, y: 2,            ease: "power3.out", duration: T }, "<")
  .to(camera.position, { x: 0, y: 1.2,  z: 5.5, ease: "none",       duration: D })
  .to(camTarget,        { x: 0, y: 2,            ease: "none",       duration: D }, "<")
// → Django
  .to(camera.position, { x: 0, y: -1.4, z: 5.5, ease: "power3.out", duration: T })
  .to(camTarget,        { x: 0, y: -0.5,         ease: "power3.out", duration: T }, "<")
  .to(camera.position, { x: 0, y: -1.4, z: 5.5, ease: "none",       duration: D })
  .to(camTarget,        { x: 0, y: -0.5,         ease: "none",       duration: D }, "<")
// → Postgres
  .to(camera.position, { x: -3.8, y: -3,  z: 5, ease: "power3.out", duration: T })
  .to(camTarget,        { x: -3,  y: -3,         ease: "power3.out", duration: T }, "<")
  .to(camera.position, { x: -3.8, y: -3,  z: 5, ease: "none",       duration: D })
  .to(camTarget,        { x: -3,  y: -3,         ease: "none",       duration: D }, "<")
// → K8s
  .to(camera.position, { x: 3.8, y: -2.7, z: 5, ease: "power3.out", duration: T })
  .to(camTarget,        { x: 3,  y: -3,          ease: "power3.out", duration: T }, "<")
  .to(camera.position, { x: 3.8, y: -2.7, z: 5, ease: "none",       duration: D })
  .to(camTarget,        { x: 3,  y: -3,          ease: "none",       duration: D }, "<");

if (!reducedMotion) {
  ScrollTrigger.create({
    trigger: "#erp-section",
    start: "top top",
    end: "bottom bottom",
    scrub: 0.7,
    animation: tl,
    onUpdate: (self) => updateBeat(self.progress * BEATS.length),
  });
}

// ── Label positioning ─────────────────────────────────────────────────────
const lblEls: Record<string, HTMLElement | null> = {
  react:    document.getElementById("lbl-react"),
  django:   document.getElementById("lbl-django"),
  postgres: document.getElementById("lbl-postgres"),
  k8s:      document.getElementById("lbl-k8s"),
};

function updateLabels() {
  const w = canvas!.clientWidth;
  const h = canvas!.clientHeight;
  const focus = FOCUS[Math.max(0, lastBeat)] ?? null;
  Object.entries(POS).forEach(([key, worldPos]) => {
    const el = lblEls[key];
    if (!el) return;
    const v = worldPos.clone().project(camera);
    const sx = (v.x * 0.5 + 0.5) * w;
    const sy = (-(v.y * 0.5) + 0.5) * h - 46; // above the node
    el.style.transform = `translate(calc(${sx}px - 50%), ${sy}px)`;
    el.style.opacity   = !focus ? "0" : key === focus ? "1" : "0.05";
  });
}

// ── Resize ────────────────────────────────────────────────────────────────
function resize() {
  const w = canvas!.clientWidth;
  const h = canvas!.clientHeight;
  renderer.setSize(w, h, false);
  camera.aspect = w / h;
  camera.updateProjectionMatrix();
}
window.addEventListener("resize", resize);
resize();

// ── IntersectionObserver: pause RAF when off-screen ───────────────────────
let visible = false;
new IntersectionObserver(
  (entries) => { visible = entries[0].isIntersecting; },
  { rootMargin: "300px" },
).observe(document.getElementById("erp-section")!);

// ── Render loop ───────────────────────────────────────────────────────────
const clock = new THREE.Clock();

if (reducedMotion) {
  updateBeat(0);
  camera.lookAt(camTarget);
  renderer.render(scene, camera);
  updateLabels();
} else {
  (function animate() {
    requestAnimationFrame(animate);
    if (!visible) return;
    const dt = clock.getDelta();
    Object.values(nodes).forEach((m) => {
      m.rotation.y += dt * 0.32;
      m.rotation.x += dt * 0.16;
    });
    Object.entries(wireframes).forEach(([key, { mesh }]) => {
      mesh.rotation.copy(nodes[key].rotation);
    });
    conns.forEach(({ a, b, particles }) => {
      particles.forEach(({ mesh }) => {
        mesh.userData.t = (mesh.userData.t + dt * 0.38) % 1;
        mesh.position.lerpVectors(POS[a], POS[b], mesh.userData.t);
      });
    });
    camera.lookAt(camTarget);
    updateLabels();
    renderer.render(scene, camera);
  })();
}

window.addEventListener("load", () => ScrollTrigger.refresh());
}
</script>
