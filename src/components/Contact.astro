---
import { SITE } from "../config";
---

<section id="contact" class="relative overflow-hidden px-6 py-[clamp(5rem,12vh,9rem)]">
  <!-- aurora horizon rising behind the CTA -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute bottom-[-30%] left-1/2 h-[34rem] w-[64rem] max-w-none -translate-x-1/2 rounded-[50%] bg-[oklch(0.55_0.12_162/0.3)] blur-[90px]"></div>
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <p class="kicker reveal mb-5 justify-center">Get in touch</p>
    <h2 class="section-statement reveal" style="--d:80ms">
      Let's build <span class="text-[var(--color-aurora)] [text-shadow:0_0_42px_oklch(0.8_0.165_162/0.45)]">together</span>
    </h2>
    <p class="reveal mx-auto mt-6 max-w-md text-[var(--color-muted)]" style="--d:160ms">
      A project to ship, a role to fill, or a question about my work: I read every message and reply personally.
    </p>

    <div class="reveal mt-10 flex flex-wrap items-center justify-center gap-3" style="--d:240ms">
      <a href={`mailto:${SITE.email}`} class="btn-aurora px-7 py-4 text-sm">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
        Email me
      </a>
      <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="btn-ghost px-7 py-4 text-sm">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5 2.5 2.5 0 01.02-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05C20.4 8.65 21 11 21 14.3V21h-4v-5.9c0-1.4 0-3.2-2-3.2s-2.3 1.5-2.3 3.1V21H9z"/></svg>
        LinkedIn
      </a>
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="btn-ghost px-7 py-4 text-sm">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49l-.01-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.9-.64.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0112 6.84c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.8-4.57 5.06.36.32.68.94.68 1.9l-.01 2.82c0 .27.18.6.69.49A10.02 10.02 0 0022 12.25C22 6.58 17.52 2 12 2z"/></svg>
        GitHub
      </a>
    </div>

    <p class="reveal mt-8 font-mono text-sm text-[var(--color-muted)]" style="--d:300ms">{SITE.email}</p>
  </div>
</section>
