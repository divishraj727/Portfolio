---
import { SITE } from "../config";
---

<section id="contact" class="relative overflow-hidden px-6 py-[clamp(5rem,12vh,9rem)]">
  <!-- aurora horizon rising behind the CTA -->
  <div class="pointer-events-none absolute inset-0" aria-hidden="true">
    <div class="absolute bottom-[-30%] left-1/2 h-[34rem] w-[64rem] max-w-none -translate-x-1/2 rounded-[50%] bg-[oklch(0.55_0.12_162/0.3)] blur-[90px]"></div>
  </div>

  <div class="relative mx-auto max-w-3xl text-center">
    <p class="hud reveal mb-5">CHANNEL OPEN · REPLIES WITHIN 24H</p>
    <h2 class="display reveal text-[clamp(2.2rem,7vw,4.5rem)]" style="--d:80ms">
      Let's build<br /><span class="text-[var(--color-aurora)] [text-shadow:0_0_42px_oklch(0.8_0.165_162/0.45)]">together</span>
    </h2>
    <p class="reveal mx-auto mt-6 max-w-md text-[var(--color-muted)]" style="--d:160ms">
      A project to ship, a role to fill, or a question about my work: I read every message and reply personally.
    </p>

    <div class="reveal mt-10 flex flex-wrap items-center justify-center gap-3" style="--d:240ms">
      <a href={`mailto:${SITE.email}`} class="btn-aurora px-8 py-4 text-sm">Email me</a>
      <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="btn-ghost px-8 py-4 text-sm">LinkedIn</a>
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="btn-ghost px-8 py-4 text-sm">GitHub</a>
    </div>

    <p class="reveal mt-8 font-mono text-sm text-[var(--color-muted)]" style="--d:300ms">{SITE.email}</p>
  </div>
</section>
