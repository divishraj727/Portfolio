---
import { SITE } from "../config";
const suggestions = [
  "Take me on a tour",
  "Walk me through the ERP architecture",
  "Is he available for hire?",
];
---

<!-- Floating launcher -->
<button
  id="chat-launch"
  aria-label="Chat with Divish's AI assistant"
  class="fixed bottom-5 right-5 z-[58] flex h-14 w-14 items-center justify-center rounded-full border border-[oklch(0.8_0.165_162/0.55)] bg-[var(--color-surface)] shadow-[0_0_26px_oklch(0.8_0.165_162/0.3)] transition-transform hover:scale-105"
>
  <img src={SITE.photo} alt="" width="48" height="48" class="h-11 w-11 rounded-full object-cover" />
  <span class="absolute -right-0.5 -top-0.5 flex h-3.5 w-3.5">
    <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-aurora)] opacity-70"></span>
    <span class="relative inline-flex h-3.5 w-3.5 rounded-full bg-[var(--color-aurora)]"></span>
  </span>
</button>

<!-- Chat panel -->
<div
  id="chat-panel"
  role="dialog"
  aria-label="AI assistant"
  class="fixed bottom-5 right-5 z-[59] flex h-[min(560px,80vh)] w-[min(380px,92vw)] origin-bottom-right scale-95 flex-col overflow-hidden rounded-3xl border border-[oklch(0.32_0.02_160/0.6)] bg-[var(--color-bg)] opacity-0 shadow-2xl transition-all duration-200 [&[hidden]]:pointer-events-none"
  hidden
>
  <!-- header -->
  <div class="flex items-center gap-3 border-b border-[oklch(0.32_0.02_160/0.5)] bg-[var(--color-surface)] px-4 py-3">
    <img src={SITE.photo} alt="" width="36" height="36" class="h-9 w-9 rounded-full border border-[oklch(0.8_0.165_162/0.5)] object-cover" />
    <div class="flex-1">
      <p class="text-sm font-bold leading-tight text-[var(--color-ink)]">Ask about {SITE.name.split(" ")[0]}</p>
      <p class="font-mono text-[10px] text-[var(--color-muted)]">AI ASSISTANT · USUALLY INSTANT</p>
    </div>
    <button id="chat-close" aria-label="Close chat" class="grid h-8 w-8 place-items-center rounded-full text-[var(--color-muted)] hover:bg-[oklch(0.8_0.165_162/0.12)] hover:text-[var(--color-aurora)]">✕</button>
  </div>

  <!-- messages -->
  <div id="chat-log" class="flex-1 space-y-3 overflow-y-auto px-4 py-4 text-sm">
    <div class="max-w-[85%] rounded-2xl rounded-tl-sm border border-[oklch(0.32_0.02_160/0.4)] bg-[var(--color-surface)] px-3.5 py-2.5 text-[var(--color-body)]">
      Hi! I'm {SITE.name.split(" ")[0]}'s AI assistant 👋 Ask me anything about his skills, projects, or availability.
    </div>
    <div id="chat-suggestions" class="flex flex-wrap gap-2 pt-1">
      {
        suggestions.map((s) => (
          <button class="chat-suggest rounded-full border border-[oklch(0.8_0.165_162/0.4)] bg-[oklch(0.8_0.165_162/0.08)] px-3 py-1.5 text-xs font-medium text-[var(--color-aurora)] transition-colors hover:bg-[oklch(0.8_0.165_162/0.18)]">
            {s}
          </button>
        ))
      }
    </div>
  </div>

  <!-- input -->
  <form id="chat-form" class="flex items-center gap-2 border-t border-[oklch(0.32_0.02_160/0.5)] bg-[var(--color-surface)] px-3 py-3">
    <input
      id="chat-input"
      type="text"
      autocomplete="off"
      placeholder="Type or speak…"
      class="min-w-0 flex-1 rounded-full border border-[oklch(0.32_0.02_160/0.6)] bg-[var(--color-bg)] px-4 py-2.5 text-sm text-[var(--color-ink)] placeholder:text-[var(--color-muted)] outline-none focus:border-[oklch(0.8_0.165_162/0.7)]"
    />
    <button type="button" id="chat-mic" aria-label="Voice input" class="relative grid h-10 w-10 shrink-0 place-items-center rounded-full border border-[oklch(0.32_0.02_160/0.6)] bg-[var(--color-surface)] text-[var(--color-muted)] transition-colors hover:border-[oklch(0.8_0.165_162/0.6)] hover:text-[var(--color-aurora)]">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="2" width="6" height="11" rx="3"/>
        <path d="M5 10a7 7 0 0 0 14 0"/><path d="M12 19v3"/><path d="M9 22h6"/>
      </svg>
      <span id="mic-ping" class="absolute -right-0.5 -top-0.5 hidden h-3 w-3">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-aurora)] opacity-70"></span>
        <span class="relative inline-flex h-3 w-3 rounded-full bg-[var(--color-aurora)]"></span>
      </span>
    </button>
    <button type="submit" aria-label="Send message" class="grid h-10 w-10 shrink-0 place-items-center rounded-full bg-[var(--color-aurora)] text-[oklch(0.13_0.02_162)] transition-transform hover:scale-105">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M3.4 20.4l17.45-7.48a1 1 0 000-1.84L3.4 3.6a1 1 0 00-1.39 1.2L4 11l11 1-11 1-1.99 6.2a1 1 0 001.39 1.2z"/></svg>
    </button>
  </form>
</div>

<script is:inline>
  (() => {
    const launch = document.getElementById("chat-launch");
    const panel = document.getElementById("chat-panel");
    const closeBtn = document.getElementById("chat-close");
    const form = document.getElementById("chat-form");
    const input = document.getElementById("chat-input");
    const log = document.getElementById("chat-log");
    if (!launch || !panel) return;

    const history = [];
    let streaming = false;

    const open = () => {
      panel.hidden = false;
      requestAnimationFrame(() => {
        panel.style.opacity = "1";
        panel.style.transform = "scale(1)";
      });
      launch.style.display = "none";
      setTimeout(() => input && input.focus(), 150);
    };
    const close = () => {
      panel.style.opacity = "0";
      panel.style.transform = "scale(0.95)";
      setTimeout(() => {
        panel.hidden = true;
        launch.style.display = "flex";
      }, 200);
    };

    launch.addEventListener("click", open);
    closeBtn && closeBtn.addEventListener("click", close);
    addEventListener("keydown", (e) => { if (e.key === "Escape" && !panel.hidden) close(); });

    // Known project links — safe hardcoded URLs, never from LLM
    const LINKS = [
      ["Nakshatra Events", "https://nakshatraevents.vercel.app/"],
      ["Peace Haven", "https://tmpeaceheaven.netlify.app/login"],
      ["EduFlow", "https://eduflow-house.vercel.app/"],
      ["ResumeAI", "https://auto-applier-job.vercel.app/"],
    ];

    const linkify = (text) => {
      const esc = text.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;").replace(/"/g,"&quot;");
      return LINKS.reduce((acc, [name, url]) => {
        return acc.replace(name, `<a href="${url}" target="_blank" rel="noopener noreferrer" style="color:var(--color-aurora);text-decoration:underline;text-underline-offset:2px">${name}</a>`);
      }, esc);
    };

    const bubble = (role, text) => {
      const div = document.createElement("div");
      div.className = role === "user"
        ? "ml-auto max-w-[85%] rounded-2xl rounded-tr-sm bg-[var(--color-aurora)] px-3.5 py-2.5 text-[oklch(0.13_0.02_162)] font-medium"
        : "max-w-[85%] rounded-2xl rounded-tl-sm border border-[oklch(0.32_0.02_160/0.4)] bg-[var(--color-surface)] px-3.5 py-2.5 text-[var(--color-body)]";
      if (text) div.textContent = text;
      log.appendChild(div);
      log.scrollTop = log.scrollHeight;
      return div;
    };

    const showFollowups = (items) => {
      const wrap = document.createElement("div");
      wrap.className = "flex flex-wrap gap-2 pt-1";
      items.forEach((q) => {
        const btn = document.createElement("button");
        btn.className = "rounded-full border border-[oklch(0.8_0.165_162/0.4)] bg-[oklch(0.8_0.165_162/0.08)] px-3 py-1.5 text-xs font-medium text-[var(--color-aurora)] transition-colors hover:bg-[oklch(0.8_0.165_162/0.18)]";
        btn.textContent = q;
        btn.addEventListener("click", () => { wrap.remove(); send(q); });
        wrap.appendChild(btn);
      });
      log.appendChild(wrap);
      log.scrollTop = log.scrollHeight;
    };

    const CURSOR_HTML = '<span style="display:inline-block;width:2px;height:0.85em;background:var(--color-aurora);margin-left:2px;vertical-align:middle;animation:blink 0.7s infinite;box-shadow:0 0 8px oklch(0.8 0.165 162/0.8)"></span>';

    // ── ERP architecture walkthrough ──────────────────────────────────────────
    const erpWalkthrough = () => {
      const sec = document.getElementById("erp-section");
      if (!sec) return;
      const returnY = window.scrollY; // snapshot where the user was before walkthrough
      bubble("assistant", "Sure! Walking you through every layer — React → Django → PostgreSQL → Kubernetes. Closing chat so you can see the 3D scene.");
      setTimeout(close, 1100);
      const go = (frac) => {
        const secTop = sec.getBoundingClientRect().top + window.scrollY;
        const top = secTop + (sec.offsetHeight - window.innerHeight) * frac;
        window.scrollTo({ top, behavior: "smooth" });   // smooth so camera glides between nodes
      };
      setTimeout(() => go(0),     1400);   // overview  (1.4 s to land on section)
      setTimeout(() => go(0.125), 2800);   // React     (1.4 s overview view)
      setTimeout(() => go(0.375), 6800);   // Django    (4 s per beat)
      setTimeout(() => go(0.625), 10800);  // PostgreSQL
      setTimeout(() => go(0.875), 14800);  // Kubernetes — dwell 5 s then return
      setTimeout(() => window.scrollTo({ top: returnY, behavior: "smooth" }), 19800);
    };

    // ── Local-command patterns (handled client-side, no API call) ─────────────
    const TOUR_RE = /\b(take.*tour|start.*tour|portfolio.*tour|tour.*portfolio|give.*tour|begin.*tour|tour)\b/i;
    const ERP_RE  = /(\berp\b.*(architect|workflow|tech|built|walk|explain|show|how|stack|system)|\b(walk|explain|show|how).*\berp\b|\barchitect\w*.*\berp\b)/i;

    const send = async (text) => {
      if (streaming) return;
      const sug = document.getElementById("chat-suggestions");
      if (sug) sug.remove();

      // Handle local commands without hitting the API
      if (TOUR_RE.test(text)) {
        bubble("user", text);
        bubble("assistant", "Launching the portfolio tour now! 🎯");
        setTimeout(() => { close(); setTimeout(() => window.startPortfolioTour?.(), 400); }, 900);
        return;
      }
      if (ERP_RE.test(text)) {
        bubble("user", text);
        erpWalkthrough();
        return;
      }

      bubble("user", text);
      history.push({ role: "user", content: text });

      const typing = bubble("assistant", "");
      typing.innerHTML = CURSOR_HTML;
      streaming = true;
      if (form) form.style.opacity = "0.6";

      try {
        const res = await fetch("/api/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ messages: history }),
        });

        if (!res.ok) throw new Error("status " + res.status);

        const ct = res.headers.get("content-type") || "";

        if (ct.includes("text/event-stream") && res.body) {
          const reader = res.body.getReader();
          const decoder = new TextDecoder();
          let buf = "";
          let full = "";

          while (true) {
            const { done, value } = await reader.read();
            if (done) break;
            buf += decoder.decode(value, { stream: true });
            const lines = buf.split("\n");
            buf = lines.pop() ?? "";

            for (const line of lines) {
              if (!line.startsWith("data: ")) continue;
              const raw = line.slice(6).trim();
              if (raw === "[DONE]") continue;
              try {
                const token = JSON.parse(raw)?.choices?.[0]?.delta?.content ?? "";
                if (token) {
                  full += token;
                  // Hide FOLLOWUPS line while streaming
                  const cut = full.indexOf("\nFOLLOWUPS:");
                  typing.textContent = cut >= 0 ? full.slice(0, cut) : full;
                  log.scrollTop = log.scrollHeight;
                }
              } catch {}
            }
          }

          // Parse FOLLOWUPS out of the completed response
          const cut = full.indexOf("\nFOLLOWUPS:");
          let display = full.trim();
          let followups = [];
          if (cut >= 0) {
            display = full.slice(0, cut).trim();
            followups = full.slice(cut + "\nFOLLOWUPS:".length)
              .split("|").map(s => s.trim()).filter(Boolean).slice(0, 3);
          }

          typing.innerHTML = linkify(display);
          history.push({ role: "assistant", content: display });
          if (followups.length) showFollowups(followups);

        } else {
          // Fallback for non-streaming JSON response
          const data = await res.json();
          const reply = data?.reply || "Sorry, I couldn't generate a reply.";
          typing.innerHTML = linkify(reply);
          history.push({ role: "assistant", content: reply });
        }

      } catch {
        typing.textContent = "I'm having trouble connecting right now. You can reach Divish directly at divishraj05@gmail.com.";
      }

      streaming = false;
      if (form) form.style.opacity = "";
      log.scrollTop = log.scrollHeight;
    };

    form && form.addEventListener("submit", (e) => {
      e.preventDefault();
      const v = (input.value || "").trim();
      if (!v) return;
      input.value = "";
      send(v);
    });

    log.addEventListener("click", (e) => {
      const t = e.target;
      if (t?.classList?.contains("chat-suggest")) send(t.textContent.trim());
    });

    // Voice navigation + chat
    const Rec = window.SpeechRecognition || window.webkitSpeechRecognition;
    const mic = document.getElementById("chat-mic");
    const micPing = document.getElementById("mic-ping");
    if (!Rec) {
      mic && (mic.style.display = "none");
    } else {
      // Navigation command map
      // scroll: short phrases OK | open: requires explicit nav verb (prevents accidental tab opens)
      // Stems used (not plurals) so "skill" matches both "skill" and "skills" via t.includes()
      const scrollTo = (id) => document.querySelector(id)?.scrollIntoView({ behavior: "smooth", block: "start" });
      const COMMANDS = [
        // Walkthroughs — fn commands, triggered by short phrase or nav verb
        { match: ["tour", "portfolio tour", "take me on a tour", "start the tour", "give me a tour"],
          fn: () => { close(); setTimeout(() => window.startPortfolioTour?.(), 350); } },
        { match: ["erp", "erp architecture", "erp workflow", "erp tech stack", "erp system",
                  "architecture walkthrough", "walk me through the erp", "explain the erp",
                  "show me the architecture", "erp walkthrough"],
          fn: () => { if (panel.hidden) erpWalkthrough(); else { open(); setTimeout(erpWalkthrough, 400); } } },
        // Scrolls — triggered by short phrase, nav verb, or "section/page" keyword
        { match: ["project", "portfolio", "your work", "show me work", "work"],       scroll: "#projects" },
        { match: ["about", "who are you", "who is divish"],                           scroll: "#about" },
        { match: ["experience", "background", "career", "education", "qualification", "certif", "cert"], scroll: "#experience" },
        { match: ["skill", "tech stack", "tooling", "technolog"],                     scroll: "#skills" },
        { match: ["contact", "get in touch", "hire", "email"],                        scroll: "#contact" },
        { match: ["top", "home", "back to top", "start", "beginning"],                scroll: "#top" },
        // External opens — require explicit nav verb only (no short-phrase shortcut)
        // ResumeAI MUST come before resume/cv so "resumeai" doesn't match the PDF entry
        { match: ["resume ai", "resumeai", "job applier", "auto apply"], open: "https://auto-applier-job.vercel.app/" },
        { match: ["resume", "cv", "download"],                           open: "/Divish-Raj-O-Resume.pdf" },
        { match: ["eduflow"],                                            open: "https://eduflow-house.vercel.app/" },
        { match: ["nakshatra", "wedding"],                               open: "https://nakshatraevents.vercel.app/" },
        { match: ["peace haven", "task manager"],                        open: "https://tmpeaceheaven.netlify.app/login" },
      ];

      // Toast confirmation
      const toast = (msg) => {
        const t = document.createElement("div");
        t.textContent = msg;
        t.style.cssText = "position:fixed;bottom:88px;right:20px;z-index:9999;background:var(--color-surface);border:1px solid oklch(0.8 0.165 162/0.5);color:var(--color-aurora);font-size:0.75rem;font-family:var(--font-sans,sans-serif);padding:8px 14px;border-radius:999px;box-shadow:0 0 16px oklch(0.8 0.165 162/0.25);pointer-events:none;transition:opacity 0.3s";
        document.body.appendChild(t);
        setTimeout(() => { t.style.opacity = "0"; setTimeout(() => t.remove(), 300); }, 2200);
      };

      // Router — scrolls allow short phrases; external opens require an explicit nav verb
      // No ^ anchor — speech often prepends "can you", "please", etc. before the verb
      const NAV_VERB = /\b(open|go to|show me|take me to|scroll to|navigate to|navigate|download|launch)\b/;
      const route = (transcript) => {
        const t = transcript.toLowerCase().replace(/[.,!?]+$/, "").trim();
        const hasNavVerb = NAV_VERB.test(t);
        const isShort = t.split(" ").length <= 3;
        const hit = COMMANDS.find(c => c.match.some(m => t.includes(m)));
        if (!hit) return false;
        const saysSection = /\b(section|page)\b/.test(t);
        if (hit.fn && (hasNavVerb || isShort || saysSection || ERP_RE.test(t) || TOUR_RE.test(t))) {
          hit.fn(); toast("→ " + t); return true;
        }
        if (hit.scroll && (hasNavVerb || isShort || saysSection)) {
          scrollTo(hit.scroll); toast("→ " + t); return true;
        }
        if (hit.open && hasNavVerb) {
          if (hit.open.startsWith("/")) window.location.href = hit.open;
          else window.open(hit.open, "_blank", "noopener");
          toast("→ " + t); return true;
        }
        return false;
      };

      const rec = new Rec();
      rec.lang = "en-IN";
      rec.interimResults = true;
      rec.continuous = false;
      let listening = false;
      mic.addEventListener("click", () => { listening ? rec.stop() : rec.start(); });
      rec.onstart = () => { listening = true; micPing.classList.remove("hidden"); mic.style.color = "var(--color-aurora)"; };
      rec.onend = () => {
        listening = false;
        micPing.classList.add("hidden");
        mic.style.color = "";
        // Auto-send whatever's in the input if routing didn't handle it
        if (input.value.trim()) { const v = input.value.trim(); input.value = ""; send(v); }
      };
      // Normalise common ASR misrecognitions of "ERP" before routing
      const normalizeASR = (t) =>
        t.replace(/\b(?:air\s*r\s*p|a\s*i\s*r\s*p|ear\s*r?\s*p|e\s*r\s*p|aierp|yeirp|ye\s*r\s*p|air\s*p|a\.r\.p|e\.r\.p)\b/gi, "erp");

      rec.onresult = (e) => {
        const last = e.results[e.results.length - 1];
        if (!last.isFinal) { input.value = last[0].transcript; return; }
        const said = last[0].transcript;
        const normalized = normalizeASR(said);
        if (route(normalized)) { input.value = ""; rec.stop(); }
        else { input.value = said; } // show original if no route matched
      };
      rec.onerror = () => { listening = false; micPing.classList.add("hidden"); mic.style.color = ""; };
    }
  })();
</script>
