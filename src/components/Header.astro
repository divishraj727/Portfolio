---
import { NAV, SITE } from "../config";
---

<header class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
    <!-- Wordmark -->
    <a
      href="#top"
      class="font-display text-sm font-bold uppercase tracking-[-0.02em] text-[var(--color-ink)] transition-colors hover:text-[var(--color-aurora)]"
      aria-label="Back to top"
    >
      Divish<span class="text-[var(--color-aurora)]">.</span>
    </a>

    <!-- Desktop nav (lg+): visible, no hidden menu -->
    <nav class="hidden items-center gap-1 rounded-full border border-[oklch(0.32_0.02_160/0.6)] bg-[oklch(0.13_0.008_160/0.7)] px-2 py-1.5 backdrop-blur-md lg:flex">
      {
        NAV.map((item) => (
          <a
            class="rounded-full px-3.5 py-1.5 font-mono text-[0.74rem] text-[var(--color-body)] transition-colors hover:bg-[oklch(0.8_0.165_162/0.12)] hover:text-[var(--color-aurora)]"
            href={item.href}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <!-- Right cluster (lg+): Resume + GitHub -->
    <div class="hidden items-center gap-2.5 lg:flex">
      <a
        href={SITE.resume}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full bg-[var(--color-aurora)] px-4 py-2 font-mono text-[0.74rem] font-semibold text-[oklch(0.13_0.02_162)] transition-transform hover:-translate-y-0.5"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3v12m0 0 4-4m-4 4-4-4" /><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
        </svg>
        Resume
      </a>
    </div>

    <!-- Mobile menu (below lg): hamburger -->
    <details class="group relative lg:hidden">
      <summary
        class="flex h-11 w-11 cursor-pointer list-none items-center justify-center rounded-full border border-[oklch(0.32_0.02_160/0.7)] bg-[oklch(0.13_0.008_160/0.75)] backdrop-blur-md transition-all hover:border-[oklch(0.8_0.165_162/0.6)] [&::-webkit-details-marker]:hidden"
        aria-label="Open menu"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-[var(--color-ink)] group-open:hidden">
          <path d="M3 6h18M3 12h18M3 18h18" />
        </svg>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden text-[var(--color-aurora)] group-open:block">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </summary>

      <nav class="absolute right-0 mt-3 w-56 overflow-hidden rounded-2xl border border-[oklch(0.32_0.02_160/0.6)] bg-[oklch(0.13_0.008_160/0.95)] p-2 shadow-2xl backdrop-blur-md">
        <ul class="font-mono text-[0.8rem]">
          {
            NAV.map((item) => (
              <li>
                <a
                  class="block rounded-xl px-4 py-2.5 text-[var(--color-body)] transition-colors hover:bg-[oklch(0.8_0.165_162/0.1)] hover:text-[var(--color-aurora)]"
                  href={item.href}
                >
                  {item.label}
                </a>
              </li>
            ))
          }
          <li class="mt-1 border-t border-[oklch(0.32_0.02_160/0.5)] pt-1">
            <a
              class="flex items-center gap-2 rounded-xl px-4 py-2.5 text-[var(--color-aurora)] transition-colors hover:bg-[oklch(0.8_0.165_162/0.1)]"
              href={SITE.resume}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 3v12m0 0 4-4m-4 4-4-4" /><path d="M4 17v2a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-2" />
              </svg>
              Download Resume
            </a>
          </li>
        </ul>
      </nav>
    </details>
  </div>
</header>
