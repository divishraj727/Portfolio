---
import { NAV, SITE } from "../config";
---

<header class="fixed left-5 top-5 z-50">
  <details class="group relative">
    <summary
      class="flex h-12 w-12 cursor-pointer list-none items-center justify-center rounded-full border border-[oklch(0.32_0.02_160/0.7)] bg-[oklch(0.13_0.008_160/0.75)] backdrop-blur-md transition-all hover:border-[oklch(0.8_0.165_162/0.6)] hover:shadow-[0_0_22px_oklch(0.8_0.165_162/0.25)] [&::-webkit-details-marker]:hidden"
      aria-label="Open menu"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="text-[var(--color-ink)] group-open:hidden">
        <path d="M3 6h18M3 12h18M3 18h18" />
      </svg>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" class="hidden text-[var(--color-aurora)] group-open:block">
        <path d="M6 6l12 12M18 6L6 18" />
      </svg>
    </summary>

    <nav class="absolute left-0 mt-3 w-60 overflow-hidden rounded-2xl border border-[oklch(0.32_0.02_160/0.6)] bg-[oklch(0.13_0.008_160/0.92)] p-2 shadow-2xl backdrop-blur-md">
      <ul class="font-mono text-[0.78rem]">
        {
          NAV.map((item) => (
            <li>
              <a
                class="block rounded-xl px-4 py-2.5 text-[var(--color-body)] transition-colors hover:bg-[oklch(0.8_0.165_162/0.1)] hover:text-[var(--color-aurora)]"
                href={item.href}
              >
                {item.label}
              </a>
            </li>
          ))
        }
        <li class="mt-1 border-t border-[oklch(0.32_0.02_160/0.5)] pt-1">
          <a
            class="block rounded-xl px-4 py-2.5 text-[var(--color-body)] transition-colors hover:bg-[oklch(0.8_0.165_162/0.1)] hover:text-[var(--color-aurora)]"
            href={SITE.github}
            target="_blank"
            rel="noopener noreferrer">GitHub ↗</a
          >
        </li>
      </ul>
    </nav>
  </details>
</header>
