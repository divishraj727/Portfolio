---
// Real, verifiable facts from the résumé — no invented metrics.
const stats = [
  { count: "4", suffix: "", label: "live products shipped", solar: false },
  { count: "3", suffix: "", label: "companies worked with", solar: false },
  { count: "2", suffix: "", label: "pro certs · RHCE, CCNA", solar: false },
  { count: "8.6", suffix: "", label: "M.Tech CGPA · RVCE", solar: true },
];
---

<section class="border-y border-[oklch(0.32_0.02_160/0.35)]">
  <div class="mx-auto grid max-w-6xl grid-cols-2 divide-[oklch(0.32_0.02_160/0.35)] px-6 max-md:gap-y-10 max-md:py-10 md:grid-cols-4 md:divide-x md:py-14">
    {
      stats.map((s, i) => (
        <div class="reveal text-center" style={`--d:${i * 90}ms`}>
          <div
            class={`font-display text-4xl font-bold sm:text-5xl ${s.solar ? "text-[var(--color-solar)]" : "text-[var(--color-ink)]"}`}
          >
            <span data-count={s.count} data-suffix={s.suffix}>0{s.suffix}</span>
          </div>
          <p class="hud mt-3">{s.label}</p>
        </div>
      ))
    }
  </div>
</section>
