---
const TOUR = [
  { sel: "#top",        title: "Welcome",        text: "Hi — I'm Divish's assistant. Let me walk you through the highlights in about 30 seconds." },
  { sel: "#about",      title: "About Divish",   text: "Full-stack developer in Bangalore. Owns the whole stack — frontend, backend, and cloud infrastructure." },
  { sel: "#experience", title: "Experience",     text: "Currently building a production ERP at Sanadi Technologies on Django, React, AWS, and Kubernetes." },
  { sel: "#skills",     title: "Skills",         text: "React and Django front-to-back, AWS and Kubernetes in the cloud. Holds RHCE and Cisco CCNA certifications." },
  { sel: "#projects",   title: "Live Projects",  text: "Four apps live right now — including EduFlow and ResumeAI, both AI-powered. Click any card to try them." },
  { sel: "#contact",    title: "Let's Connect",  text: "Open to full-time roles and freelance projects. Reach out any time — Divish would love to hear from you." },
];
const total = TOUR.length;
---

<!-- Backdrop + card -->
<div id="tour-overlay" hidden role="dialog" aria-modal="true" aria-label="Portfolio tour">
  <div id="tour-backdrop" class="fixed inset-0 z-[148] bg-[oklch(0.09_0.02_160/0.78)]"></div>

  <div id="tour-card" class="fixed bottom-6 left-1/2 z-[149] w-[min(500px,92vw)] -translate-x-1/2 rounded-2xl border border-[oklch(0.8_0.165_162/0.5)] bg-[var(--color-bg)] p-5 shadow-[0_0_48px_oklch(0.8_0.165_162/0.22)]">
    <!-- Progress dots -->
    <div class="mb-3.5 flex justify-center gap-2">
      {TOUR.map((_, i) => (
        <span class="tour-dot block h-1.5 rounded-full bg-[oklch(0.32_0.02_160/0.5)] transition-all duration-300" style={`width:${i === 0 ? 20 : 6}px`}></span>
      ))}
    </div>

    <!-- Label + text -->
    <p id="tour-label" class="mb-1 font-mono text-[10px] uppercase tracking-widest text-[var(--color-aurora)]">Welcome</p>
    <p id="tour-text" class="min-h-[2.8rem] text-sm leading-relaxed text-[var(--color-body)]"></p>

    <!-- Controls -->
    <div class="mt-4 flex items-center justify-between gap-2">
      <div class="flex gap-2">
        <button id="tour-back" class="rounded-full border border-[oklch(0.32_0.02_160/0.6)] px-3.5 py-1.5 text-xs text-[var(--color-muted)] transition-colors hover:border-[oklch(0.8_0.165_162/0.5)] hover:text-[var(--color-body)]">← Back</button>
        <button id="tour-skip" class="rounded-full border border-[oklch(0.32_0.02_160/0.6)] px-3.5 py-1.5 text-xs text-[var(--color-muted)] transition-colors hover:border-[oklch(0.8_0.165_162/0.5)] hover:text-[var(--color-body)]">Skip tour</button>
      </div>
      <div class="flex gap-2">
        <button id="tour-voice" aria-label="Toggle narration" title="Toggle narration" class="grid h-8 w-8 shrink-0 place-items-center rounded-full border border-[oklch(0.32_0.02_160/0.6)] text-[var(--color-aurora)] transition-colors hover:bg-[oklch(0.8_0.165_162/0.1)]">
          <svg id="tour-voice-icon" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/></svg>
        </button>
        <button id="tour-next" class="rounded-full bg-[var(--color-aurora)] px-4 py-1.5 text-xs font-bold text-[oklch(0.13_0.02_162)] transition-opacity hover:opacity-90">Next →</button>
      </div>
    </div>
  </div>
</div>

<!-- First-visit prompt (shown once, auto-dismissed after tour or "no thanks") -->
<div id="tour-prompt" hidden class="fixed bottom-[5.5rem] left-5 z-[60] max-w-[210px] rounded-2xl border border-[oklch(0.8_0.165_162/0.4)] bg-[var(--color-surface)] p-3.5 shadow-[0_0_20px_oklch(0.8_0.165_162/0.2)]">
  <p class="mb-2.5 text-xs leading-snug text-[var(--color-body)]">👋 Want a quick 30-sec tour of Divish's portfolio?</p>
  <div class="flex gap-2">
    <button id="tour-prompt-yes" class="rounded-full bg-[var(--color-aurora)] px-3 py-1 text-[11px] font-bold text-[oklch(0.13_0.02_162)]">Sure!</button>
    <button id="tour-prompt-no" class="rounded-full border border-[oklch(0.32_0.02_160/0.5)] px-3 py-1 text-[11px] text-[var(--color-muted)] hover:text-[var(--color-body)] transition-colors">No thanks</button>
  </div>
</div>

<script is:inline define:vars={{ TOUR, total }}>
  (() => {
    const overlay   = document.getElementById("tour-overlay");
    const backdrop  = document.getElementById("tour-backdrop");
    const card      = document.getElementById("tour-card");
    const labelEl   = document.getElementById("tour-label");
    const textEl    = document.getElementById("tour-text");
    const dotsEl    = card ? card.querySelectorAll(".tour-dot") : [];
    const btnBack   = document.getElementById("tour-back");
    const btnSkip   = document.getElementById("tour-skip");
    const btnNext   = document.getElementById("tour-next");
    const btnVoice  = document.getElementById("tour-voice");
    const voiceIcon = document.getElementById("tour-voice-icon");
    const prompt    = document.getElementById("tour-prompt");
    if (!overlay) return;

    const reducedMotion = matchMedia("(prefers-reduced-motion: reduce)").matches;
    const hasSpeech     = "speechSynthesis" in window;
    let voiceOn  = hasSpeech;
    let step     = 0;
    let autoTimer = null;
    let active   = false;

    // Voice icon paths
    const ICON_ON  = '<path d="M3 9v6h4l5 5V4L7 9H3zm13.5 3c0-1.77-1.02-3.29-2.5-4.03v8.05c1.48-.73 2.5-2.25 2.5-4.02z"/>';
    const ICON_OFF = '<path d="M16.5 12c0-1.77-1.02-3.29-2.5-4.03v2.21l2.45 2.45c.03-.2.05-.41.05-.63zm2.5 0c0 .94-.2 1.82-.54 2.64l1.51 1.51C20.63 14.91 21 13.5 21 12c0-4.28-2.99-7.86-7-8.77v2.06c2.89.86 5 3.54 5 6.71zM4.27 3L3 4.27 7.73 9H3v6h4l5 5v-6.73l4.25 4.25c-.67.52-1.42.93-2.25 1.18v2.06c1.38-.31 2.63-.95 3.69-1.81L19.73 21 21 19.73l-9-9L4.27 3zM12 4L9.91 6.09 12 8.18V4z"/>';

    const setVoiceIcon = () => {
      if (voiceIcon) voiceIcon.innerHTML = voiceOn ? ICON_ON : ICON_OFF;
      if (btnVoice) btnVoice.style.color = voiceOn ? "var(--color-aurora)" : "var(--color-muted)";
    };
    setVoiceIcon();
    if (!hasSpeech && btnVoice) btnVoice.style.display = "none";

    const updateDots = () => {
      dotsEl.forEach((d, i) => {
        d.style.width = i === step ? "20px" : "6px";
        d.style.background = i <= step ? "var(--color-aurora)" : "oklch(0.32 0.02 160 / 0.5)";
      });
    };

    const clearAuto = () => { clearTimeout(autoTimer); };

    const scheduleNext = (delay) => {
      clearAuto();
      autoTimer = setTimeout(() => {
        if (step < total - 1) { step++; show(); }
        else endTour();
      }, delay);
    };

    const speak = (text) => {
      if (!hasSpeech || !voiceOn) { scheduleNext(4000); return; }
      speechSynthesis.cancel();
      const u = new SpeechSynthesisUtterance(text);
      u.rate = 1.05; u.pitch = 1; u.lang = "en-US";
      u.onend = () => { if (active) scheduleNext(700); };
      u.onerror = () => { if (active) scheduleNext(3500); };
      speechSynthesis.speak(u);
    };

    const show = () => {
      const s = TOUR[step];
      labelEl.textContent = s.title;
      textEl.textContent  = s.text;
      btnNext.textContent = step === total - 1 ? "Finish ✓" : "Next →";
      btnBack.disabled    = step === 0;
      btnBack.style.opacity = step === 0 ? "0.35" : "";
      updateDots();
      document.querySelector(s.sel)?.scrollIntoView({ behavior: reducedMotion ? "auto" : "smooth", block: "start" });
      speak(s.text);
    };

    const startTour = () => {
      step = 0;
      active = true;
      overlay.hidden = false;
      show();
      localStorage.setItem("divish_tour_seen", "1");
    };

    const endTour = () => {
      active = false;
      clearAuto();
      if (hasSpeech) speechSynthesis.cancel();
      overlay.hidden = true;
      localStorage.setItem("divish_tour_seen", "1");
    };

    // Button handlers
    btnNext  && btnNext.addEventListener("click", () => { clearAuto(); if (step < total - 1) { step++; show(); } else endTour(); });
    btnBack  && btnBack.addEventListener("click", () => { clearAuto(); if (step > 0) { step--; show(); } });
    btnSkip  && btnSkip.addEventListener("click", endTour);
    backdrop && backdrop.addEventListener("click", endTour);
    btnVoice && btnVoice.addEventListener("click", () => {
      voiceOn = !voiceOn;
      setVoiceIcon();
      if (!voiceOn && hasSpeech) { speechSynthesis.cancel(); scheduleNext(3500); }
      else if (voiceOn) { clearAuto(); speak(TOUR[step].text); }
    });

    // Keyboard
    addEventListener("keydown", (e) => {
      if (!active) return;
      if (e.key === "Escape") endTour();
      if (e.key === "ArrowRight" && step < total - 1) { clearAuto(); step++; show(); }
      if (e.key === "ArrowLeft"  && step > 0)          { clearAuto(); step--; show(); }
    });

    // Expose globally so Hero trigger button can call it
    window.startPortfolioTour = startTour;

    // First-visit prompt
    if (prompt) {
      const seen = localStorage.getItem("divish_tour_seen");
      if (!seen) {
        setTimeout(() => { prompt.hidden = false; }, 2500);
      }
      document.getElementById("tour-prompt-yes") && document.getElementById("tour-prompt-yes").addEventListener("click", () => {
        prompt.hidden = true; startTour();
      });
      document.getElementById("tour-prompt-no") && document.getElementById("tour-prompt-no").addEventListener("click", () => {
        prompt.hidden = true;
        localStorage.setItem("divish_tour_seen", "1");
      });
    }
  })();
</script>
