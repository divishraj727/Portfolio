---
import { SITE } from "../config";
const year = new Date().getFullYear();
---

<footer class="border-t border-[oklch(0.32_0.02_160/0.35)]">
  <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-3 px-6 py-8 font-mono text-[0.7rem] text-[var(--color-muted)] sm:flex-row">
    <p>© {year} {SITE.name} · {SITE.location}</p>
    <p>
      Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-[var(--color-aurora)] hover:underline">Astro</a>,
      Three.js &amp; Tailwind CSS
    </p>
  </div>
</footer>
