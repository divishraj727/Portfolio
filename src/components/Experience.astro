---
import { EXPERIENCE, EDUCATION, CERTIFICATIONS } from "../config";
---

<section id="experience" class="mx-auto max-w-3xl px-6 py-[clamp(4rem,10vh,8rem)]">
  <p class="kicker reveal mb-5">Background</p>
  <h2 class="section-title reveal mb-14">
    Experience <span class="text-[var(--color-aurora)]">&amp;</span> education
  </h2>

  <ol class="relative border-l border-[oklch(0.32_0.02_160/0.5)]">
    {
      EXPERIENCE.map((job, i) => (
        <li class="reveal mb-12 ml-7" style={`--d:${i * 80}ms`}>
          <span class="absolute -left-[5.5px] mt-1.5 h-[11px] w-[11px] rounded-full bg-[var(--color-aurora)] shadow-[0_0_14px_oklch(0.8_0.165_162/0.8)]" />
          <p class="hud mb-2">{job.period}</p>
          <h3 class="font-display text-lg font-bold text-[var(--color-ink)]">
            {job.role} <span class="text-[var(--color-aurora)]">· {job.company}</span>
          </h3>
          <ul class="mt-3 space-y-2">
            {job.points.map((p) => (
              <li class="flex gap-3 text-[0.95rem] leading-relaxed text-[var(--color-body)]">
                <span class="mt-[0.6rem] h-px w-3 shrink-0 bg-[oklch(0.8_0.165_162/0.5)]" />
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }

    {
      EDUCATION.map((ed, i) => (
        <li class="reveal mb-12 ml-7" style={`--d:${i * 80}ms`}>
          <span class="absolute -left-[5.5px] mt-1.5 h-[11px] w-[11px] rounded-full border border-[oklch(0.66_0.02_160/0.8)] bg-[var(--color-bg)]" />
          <p class="hud mb-2">{ed.period} · {ed.detail}</p>
          <h3 class="font-display text-lg font-bold text-[var(--color-ink)]">
            {ed.degree} <span class="text-[var(--color-muted)]">· {ed.school}</span>
          </h3>
        </li>
      ))
    }
  </ol>

  <div class="reveal mt-4" style="--d:160ms">
    <p class="kicker mb-4">Certifications</p>
    <div class="flex flex-wrap gap-3">
      {
        CERTIFICATIONS.map((c) => {
          const Tag = c.verify ? "a" : "div";
          return (
            <Tag
              href={c.verify}
              target={c.verify ? "_blank" : undefined}
              rel={c.verify ? "noopener noreferrer" : undefined}
              class="group inline-flex items-center gap-3 rounded-xl border border-[oklch(0.32_0.02_160/0.6)] bg-[var(--color-surface)] px-4 py-3 transition-colors hover:border-[oklch(0.8_0.165_162/0.5)]"
            >
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.8"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="shrink-0 text-[var(--color-aurora)]"
                aria-hidden="true"
              >
                <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
              <span class="text-left">
                <span class="block text-sm font-medium text-[var(--color-ink)]">{c.name}</span>
                <span class="block font-mono text-[0.66rem] text-[var(--color-muted)]">
                  {c.meta}
                  {c.verify && <span class="text-[var(--color-aurora)]"> · Verify ↗</span>}
                </span>
              </span>
            </Tag>
          );
        })
      }
    </div>
  </div>
</section>
