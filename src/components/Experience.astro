---
import { EXPERIENCE, EDUCATION, CERTIFICATIONS } from "../config";
---

<section id="experience" class="mx-auto max-w-3xl px-6 py-[clamp(4rem,10vh,8rem)]">
  <p class="kicker reveal mb-5">Background</p>
  <h2 class="section-title reveal mb-14">
    Experience <span class="text-[var(--color-aurora)]">&amp;</span> education
  </h2>

  <ol class="relative border-l border-[oklch(0.32_0.02_160/0.5)]">
    {
      EXPERIENCE.map((job, i) => (
        <li class="reveal mb-12 ml-7" style={`--d:${i * 80}ms`}>
          <span class="absolute -left-[5.5px] mt-1.5 h-[11px] w-[11px] rounded-full bg-[var(--color-aurora)] shadow-[0_0_14px_oklch(0.8_0.165_162/0.8)]" />
          <p class="hud mb-2">{job.period}</p>
          <h3 class="font-display text-lg font-bold text-[var(--color-ink)]">
            {job.role} <span class="text-[var(--color-aurora)]">· {job.company}</span>
          </h3>
          <ul class="mt-3 space-y-2">
            {job.points.map((p) => (
              <li class="flex gap-3 text-[0.95rem] leading-relaxed text-[var(--color-body)]">
                <span class="mt-[0.6rem] h-px w-3 shrink-0 bg-[oklch(0.8_0.165_162/0.5)]" />
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </li>
      ))
    }

    {
      EDUCATION.map((ed, i) => (
        <li class="reveal mb-12 ml-7" style={`--d:${i * 80}ms`}>
          <span class="absolute -left-[5.5px] mt-1.5 h-[11px] w-[11px] rounded-full border border-[oklch(0.66_0.02_160/0.8)] bg-[var(--color-bg)]" />
          <p class="hud mb-2">{ed.period} · {ed.detail}</p>
          <h3 class="font-display text-lg font-bold text-[var(--color-ink)]">
            {ed.degree} <span class="text-[var(--color-muted)]">· {ed.school}</span>
          </h3>
        </li>
      ))
    }
  </ol>

  <div class="reveal mt-2 flex flex-wrap gap-2.5" style="--d:160ms">
    {
      CERTIFICATIONS.map((c) => (
        <span class="rounded-full border border-[oklch(0.6_0.13_70/0.45)] bg-[oklch(0.6_0.13_70/0.12)] px-4 py-1.5 font-mono text-xs text-[oklch(0.78_0.12_75)]">
          ✓ {c}
        </span>
      ))
    }
  </div>
</section>
