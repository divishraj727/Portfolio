---
import { SITE } from "../config";
import SpiralScene from "./SpiralScene.astro";
---

<section id="top" class="aurora-haze relative min-h-[100svh] overflow-hidden">
  <SpiralScene />

  <!-- legibility scrim: darkest under the centred text, fading up so the galaxy stays bright -->
  <div
    class="pointer-events-none absolute inset-0 z-[5]"
    style="background: radial-gradient(125% 95% at 50% 64%, oklch(0.09 0 0 / 0.92) 0%, oklch(0.09 0 0 / 0.55) 40%, transparent 74%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 mx-auto flex min-h-[100svh] max-w-6xl flex-col justify-center px-6 py-24">
    <div class="reveal mb-6 inline-flex items-center gap-3 self-start rounded-full border border-[oklch(0.32_0.02_160/0.6)] bg-[oklch(0.13_0.008_160/0.7)] py-1.5 pl-1.5 pr-4 backdrop-blur-sm" style="--d:80ms">
      <img src={SITE.photo} alt={SITE.name} width="32" height="32" class="h-8 w-8 rounded-full border border-[oklch(0.8_0.165_162/0.5)] object-cover" />
      <span class="relative flex h-2 w-2">
        <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-[var(--color-aurora)] opacity-60"></span>
        <span class="relative inline-flex h-2 w-2 rounded-full bg-[var(--color-aurora)]"></span>
      </span>
      <span class="text-sm font-medium text-[var(--color-body)]">Open to opportunities · {SITE.location}</span>
    </div>

    <p class="hud reveal mb-4" style="--d:140ms">Software Engineer</p>

    <h1 class="display reveal text-[clamp(2.5rem,10.5vw,5.5rem)]" style="--d:200ms">
      Divish<br />
      <span class="text-[var(--color-aurora)] [text-shadow:0_0_42px_oklch(0.8_0.165_162/0.45)]">Raj O</span>
    </h1>

    <p class="reveal mt-6 max-w-xl text-lg leading-relaxed text-[var(--color-body)] sm:text-xl" style="--d:280ms">
      {SITE.tagline}
    </p>

    <div class="reveal mt-9 flex flex-wrap items-center gap-3" style="--d:360ms">
      <a href="#projects" class="btn-aurora px-7 py-3.5 text-sm">View projects</a>
      <a href="#contact" class="btn-ghost px-7 py-3.5 text-sm">Contact me</a>
      <span class="mx-1 hidden h-6 w-px bg-[oklch(0.32_0.02_160/0.6)] sm:block"></span>
      <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="icon-orb" aria-label="LinkedIn profile">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M4.98 3.5a2.5 2.5 0 11-.02 5 2.5 2.5 0 01.02-5zM3 9h4v12H3zM9 9h3.8v1.7h.05c.53-1 1.83-2.05 3.77-2.05C20.4 8.65 21 11 21 14.3V21h-4v-5.9c0-1.4 0-3.2-2-3.2s-2.3 1.5-2.3 3.1V21H9z"/></svg>
      </a>
      <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="icon-orb" aria-label="GitHub profile">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.58 2 12.25c0 4.53 2.87 8.37 6.84 9.73.5.1.68-.22.68-.49l-.01-1.7c-2.78.62-3.37-1.37-3.37-1.37-.46-1.18-1.11-1.5-1.11-1.5-.9-.64.07-.62.07-.62 1 .07 1.53 1.05 1.53 1.05.89 1.57 2.34 1.12 2.91.86.09-.66.35-1.12.63-1.38-2.22-.26-4.56-1.14-4.56-5.07 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.7 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0112 6.84c.85 0 1.71.12 2.51.34 1.91-1.33 2.75-1.05 2.75-1.05.55 1.4.2 2.44.1 2.7.64.72 1.03 1.63 1.03 2.75 0 3.94-2.34 4.8-4.57 5.06.36.32.68.94.68 1.9l-.01 2.82c0 .27.18.6.69.49A10.02 10.02 0 0022 12.25C22 6.58 17.52 2 12 2z"/></svg>
      </a>
    </div>
  </div>

  <!-- subtle scroll cue -->
  <div class="absolute bottom-7 left-1/2 z-10 hidden -translate-x-1/2 sm:block" aria-hidden="true">
    <span class="scroll-line block h-10 w-px bg-[oklch(0.8_0.165_162/0.45)]"></span>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: no-preference) {
    .scroll-line {
      transform-origin: top;
      animation: scrollPulse 2.2s cubic-bezier(0.22, 1, 0.36, 1) infinite;
    }
    @keyframes scrollPulse {
      0% { transform: scaleY(0); opacity: 0; }
      35% { transform: scaleY(1); opacity: 1; }
      100% { transform: scaleY(1) translateY(10px); opacity: 0; }
    }
  }
</style>
