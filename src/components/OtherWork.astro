---
import { OTHER_WORK } from "../config";

// icon + accent per kind of work
const META: Record<string, { color: string; border: string; icon: string }> = {
  Production: {
    color: "var(--color-aurora)",
    border: "oklch(0.8 0.165 162 / 0.5)",
    icon: '<path d="M12 2 2 7l10 5 10-5-10-5Z"/><path d="m2 17 10 5 10-5"/><path d="m2 12 10 5 10-5"/>',
  },
  "M.Tech research": {
    color: "var(--color-solar)",
    border: "oklch(0.6 0.13 70 / 0.5)",
    icon: '<path d="M9 3h6"/><path d="M10 3v6.5L4.5 19a1 1 0 0 0 .9 1.5h13.2a1 1 0 0 0 .9-1.5L14 9.5V3"/><path d="M7.5 15h9"/>',
  },
  DevOps: {
    color: "var(--color-ink)",
    border: "oklch(0.42 0.03 160 / 0.7)",
    icon: '<rect x="2" y="3" width="20" height="18" rx="2"/><path d="m6 8 4 4-4 4"/><path d="M12 16h6"/>',
  },
};
---

<section id="work-more" class="mx-auto max-w-6xl px-6 py-[clamp(4rem,10vh,8rem)]">
  <p class="kicker reveal mb-5">Beyond the demos</p>
  <h2 class="section-title reveal mb-4">
    Production <span class="text-[var(--color-aurora)]">&amp;</span> research
  </h2>
  <p class="reveal mb-12 max-w-lg text-[var(--color-muted)]" style="--d:80ms">
    Work that doesn't live at a public URL: a production system in daily use, and research I built end to end.
  </p>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {
      OTHER_WORK.map((w, i) => {
        const m = META[w.kind] ?? META.DevOps;
        return (
          <article class="panel reveal flex flex-col p-6" style={`--d:${i * 90}ms`}>
            <div class="flex items-center justify-between">
              <span
                class="grid h-11 w-11 place-items-center rounded-xl border bg-[oklch(0.17_0.012_160/0.6)]"
                style={`border-color:${m.border};color:${m.color}`}
              >
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={m.icon} />
              </span>
              <span
                class="rounded-full border px-2.5 py-1 font-mono text-[0.62rem] uppercase tracking-wide"
                style={`border-color:${m.border};color:${m.color}`}
              >
                {w.kind}
              </span>
            </div>

            <h3 class="mt-5 font-display text-lg font-semibold leading-snug text-[var(--color-ink)]">
              {w.title}
            </h3>
            <p class="mt-3 flex-1 text-[0.92rem] leading-relaxed text-[var(--color-body)]">
              {w.description}
            </p>

            <ul class="mt-5 flex flex-wrap gap-2">
              {w.tags.map((t) => (
                <li class="rounded-md border border-[oklch(0.32_0.02_160/0.45)] bg-[var(--color-surface-2)] px-2 py-0.5 font-mono text-[0.62rem] text-[var(--color-muted)]">
                  {t}
                </li>
              ))}
            </ul>
          </article>
        );
      })
    }
  </div>
</section>
